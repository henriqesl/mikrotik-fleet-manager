APP_NAME=ARGOS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

MANAGEMENT_NETWORKS=["10.200.0.0/16"]
ALLOWED_ROUTER_API_PORTS=[8729]

CREDENTIAL_ENCRYPTION_KEY=replace-with-a-generated-fernet-key

ROUTEROS_CA_FILE=certs/routeros-ca.pem
ROUTEROS_SOCKET_TIMEOUT_SECONDS=5

MAX_CONCURRENT_ROUTER_CHECKS=20
POLL_INTERVAL_SECONDS=60
POLL_BATCH_SIZE=20
POLL_SCHEDULER_TICK_SECONDS=1
POLL_LEASE_SECONDS=120
POLL_MAX_BACKOFF_SECONDS=900
POLL_INITIAL_STAGGER_SECONDS=60

POLLING_ENABLED=true
LOG_LEVEL=INFO

CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=sqlite+aiosqlite:///./argos.db
DATABASE_ECHO=false

SQLITE_WAL_ENABLED=true
SQLITE_BUSY_TIMEOUT_MS=5000
