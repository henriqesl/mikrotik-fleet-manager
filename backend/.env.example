APP_NAME=ARGOS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

MANAGEMENT_NETWORKS=["10.200.0.0/16"]
ALLOWED_ROUTER_API_PORTS=[8729]

CREDENTIAL_ENCRYPTION_KEY=replace-with-a-generated-fernet-key

ROUTEROS_CA_FILE=certs/routeros-ca.pem
ROUTEROS_SOCKET_TIMEOUT_SECONDS=5

CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=sqlite+aiosqlite:///./argos.db

